# (0) choose an appropriate name for the component
project('timekeeper-plugin', 'c', 
  version : '0.2.0.0',
  meson_version : '>=0.61.2',
  default_options : [
    'default_library=shared',
    'optimization=s',
    'debug=false'])
project_name = 'comp-templ'

# get the basic build properties
platform = get_option('build_platform')
class = get_option('build_class')

# (1) these variables will hold the dependencies, definitions and paths
# CSP, SALLY, console and commands dependencies are handled automatically, depending on meson options
component_deps = []
backend_defs = []
extra_inc_dirs = []
backend_src = files()
dep_options = {}

# (2) create the platform-specific configuration
if platform == 'Linux'
  # (2.1) set platform-specific backend sources
  backend_src += files(
    'lib/sally-backends/fs/posix_backend.c',
    'lib/sally-backends/os/posix_backend.c',
    'lib/sally-backends/com/posix_tty_backend.c',
    'lib/sally-backends/com/memcom_backend.c',
  )

  # (2.2) set the definitions that can be used in code
  backend_defs += '-DFS_BACKEND=backend_fs_posix'
  backend_defs += '-DOS_BACKEND=backend_os_posix'
  backend_defs += '-DCOM_BACKEND=backend_posix_tty'

  # (2.3) set the libraries that are needed for this specific platform 
  component_deps += dependency('threads')

  # (2.4) set the platform-specific configuration for dependencies (for example, CSP)
  if get_option('enable_csp')
    dep_options += { 
      'csp': [
        'csp_platform=posix',
        'csp_use_ifc_kiss=true',
        'csp_usart_linux=true',
        'csp_use_dedup=false',
      ]
    }
  endif

else
  warning('Unknown platform: "' + platform + '", build will likely fail!')

endif

# (3) explicitly set the sources
# NOTE: this example combines CSP and COM-port communication, so decide which one will be used
# in real life, only one of these options will typically be needed
if get_option('enable_csp')
  client_lib_src = files('cli/src/client_tk.c')
  server_lib_src = files('srv/src/server_tk.c')
else
  client_lib_src = files('cli/src/client_com.c')
  server_lib_src = files('srv/src/server_com.c')
endif

# (3.1) add sources common to both client and server
# NOTE: if lpldgen is used, do not add it here, as it is handled automatically!
common_src = files()

# (3.2) if client commands are to be built, specify the sources here
if get_option('build_cmdline') != 'none'
  client_cmd_src = files('cli/cmd/tk_cmd.c')
endif

# (3.3) if some autotests are to be built, specify the sources
if get_option('build_autotest')
  if get_option('enable_csp')
    client_bin_src = files('autotest/cli/client_csp.c')
    server_bin_src = files('autotest/srv/server_csp.c')
    combined_bin_src = files('autotest/comb/combined_csp.c')
  else
    client_bin_src = files('autotest/cli/client_com.c')
    server_bin_src = files('autotest/srv/server_com.c')
    combined_bin_src = files('autotest/comb/combined_com.c')
  endif
endif

# (4) set the project-specific configuration
#     this takes options from meson_options.txt (or provided from commandline)
#     and builds the configuration file based on the .in template
#     when unused, set common_config_path = ''
common_config_path = 'common/include/templ'
common_config = configuration_data()
common_config.set('TEMPLATE_OPTION', get_option('template_option'))

# (5) any miscellanous user configuration should go here

# (6) end of user configuration
# everything else is handled by base.meson.build file from the tools submodule
